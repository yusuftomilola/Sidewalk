{
  "name": "sidewalk",
  "version": "0.1.0",
  "private": true,
  "description": "Open source hackathon starter for Sidewalk.",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "dev:api": "pnpm --filter @sidewalk/api dev",
    "dev:web": "pnpm --filter @sidewalk/web dev",
    "dev:mobile": "pnpm --filter @sidewalk/mobile dev",
    "dev:stellar": "pnpm --filter @sidewalk/stellar-service dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "check": "pnpm lint && pnpm typecheck && pnpm build"
  },
  "devDependencies": {
    "@eslint/js": "^9.27.0",
    "@types/node": "^22.15.30",
    "eslint": "^9.27.0",
    "globals": "^15.15.0",
    "turbo": "^2.5.3",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.32.0"
  }
}
