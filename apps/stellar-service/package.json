    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/express": "^5.0.1",
    "@types/supertest": "6.0.3",
    "supertest": "7.1.0",
    "tsx": "^4.19.4",
    "vitest": "3.2.2"
  }
}
